DRIVER=~httpx+~websockets
LOCALSTORE_CACHE_DIR="data/cache"
LOCALSTORE_DATA_DIR="data"
LOCALSTORE_CONFIG_DIR="data/config"

# 基础配置
HOST=127.0.0.1
PORT=8080
NICKNAME=["QQ Copilot Bot"]
COMMAND_START=["/", ""]

# OneBot V11 配置
ONEBOT_ACCESS_TOKEN=""
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]

# MySQL 配置
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=qq_copilot_bot

# Copilot 对话 API 配置
COPILOT_API_URL=http://127.0.0.1:4141/v1/chat/completions
COPILOT_MODEL=gpt-4o
COPILOT_TIMEOUT=60
COPILOT_MAX_TURNS=10
COPILOT_SYSTEM_PROMPT=""